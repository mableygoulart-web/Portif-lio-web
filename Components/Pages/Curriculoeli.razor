<h3>Curriculo</h3>
@page "/CurriculoEli"

<div class="pagina-inicial">
    <div class="secao-banner">
        <div class="banner-principal">
            <p class="subtitulo-banner">Eliezer | Desenvolvedor em Formação</p>
            <h1 class="titulo-banner">Currículo Profissional</h1>
            <p class="texto-banner">
                Estudante de T.I. pelo IFRO com foco em resolução de problemas, lógica de automação e visão empreendedora.
            </p>
        </div>
    </div>

    <div class="secao-destaques">
    
        <div class="cartao-destaque">
            <span class="numero-destaque">Educação</span>
            <h2>Técnico em Informática</h2>
            <p>
                <strong>IFRO - Campus Ji-Paraná</strong><br />
                Formação técnica com foco em desenvolvimento de sistemas, redes e banco de dados.
            </p>
            <p>Previsão de conclusão: 2026</p>
        </div>

    
        <div class="cartao-destaque">
            <span class="numero-destaque">Certificação</span>
            <h2>Robótica LEGO</h2>
            <p>
                <strong>Nível 1 e 2</strong><br />
                Desenvolvimento de lógica de programação aplicada, construção de algoritmos para automação e trabalho em equipe sob pressão.
            </p>
        </div>

        
        <div class="cartao-destaque">
            <span class="numero-destaque">Certificação</span>
            <h2>Empreendedorismo</h2>
            <p>
                <strong>DFE</strong><br />
                Capacitação em visão de mercado, gestão de processos e inovação tecnológica voltada para soluções reais.
            </p>
        </div>

    
        <div class="cartao-destaque">
            <span class="numero-destaque">Extra</span>
            <h2>Habilidades Básicas</h2>
            <p>
                Informática basica, manutenção de sistemas e suporte ao usuário. Familiaridade com ferramentas de produtividade.
            </p>
        </div>


        <div class="cartao-destaque cartao-destaque-contato">
            <span class="numero-destaque">Localização</span>
            <h2>Nova Londrina / RO</h2>
            <p>Disponível para projetos remotos e oportunidades na região de Ji-Paraná.</p>
            <a href="mailto:seuemail@exemplo.com" </a> 
            <a href="/" class="cartao-destaque a" style="padding: 1rem 2rem; border-radius: 50px;">Voltar ao inicio</a>
        </div>
    </div>
</div>

